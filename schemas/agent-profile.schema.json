{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/agent-profile.schema.json",
  "title": "Agent Profile",
  "type": "object",
  "required": [
    "agent",
    "traits",
    "leadershipPrinciples",
    "scenarios"
  ],
  "properties": {
    "agent": {
      "type": "object",
      "required": [
        "name",
        "workspacePath"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "workspacePath": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "archetype": {
          "type": "string"
        },
        "temperament": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "workspaceStats": {
          "type": "object",
          "properties": {
            "fileCount": {
              "type": "number",
              "minimum": 0
            },
            "instructionFileCount": {
              "type": "number",
              "minimum": 0
            },
            "configFileCount": {
              "type": "number",
              "minimum": 0
            },
            "skillFileCount": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "sourceFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "traits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "score",
          "summary",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "summary": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "kind",
                "source",
                "detail"
              ],
              "properties": {
                "kind": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                },
                "detail": {
                  "type": "string"
                },
                "weight": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "leadershipPrinciples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "score",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "prompt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "predictedBehavior": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
